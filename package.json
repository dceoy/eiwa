{
  "name": "eiwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A mobile-first English-Japanese / Japanese-English dictionary web app with browser-side WebLLM translation.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run dict:build && pnpm run dict:validate && tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.worker.json && tsc --noEmit -p tsconfig.node.json",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "dict:build": "tsx scripts/build-dict-shards.ts",
    "dict:validate": "tsx scripts/validate-dict.ts",
    "deploy:temporary": "wrangler deploy --temporary",
    "smoke:url": "tsx scripts/smoke-url.ts",
    "audit": "pnpm audit --prod"
  },
  "dependencies": {
    "preact": "10.29.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@cloudflare/workers-types": "5.20260703.1",
    "@mlc-ai/web-llm": "0.2.84",
    "@playwright/test": "1.61.1",
    "@preact/preset-vite": "2.10.5",
    "@testing-library/preact": "3.2.4",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.0",
    "happy-dom": "20.10.6",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "wrangler": "4.107.0",
    "tsx": "4.19.2"
  },
  "packageManager": "pnpm@11.8.0"
}
